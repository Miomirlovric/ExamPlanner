<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ExamPlanner.ViewModels"
             x:Class="ExamPlanner.Views.CentralityResultsView"
             x:DataType="vm:SectionEditorViewModel">

    <VerticalStackLayout Spacing="12">

        <!-- Degree -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <Label Text="Najveću centralnost stupnja ima vrh" VerticalOptions="Center" />
            <Border Grid.Column="1" Padding="8,4" StrokeShape="RoundRectangle 4" BackgroundColor="#E0E0E0">
                <Label Text="{Binding DegreeVertices}" FontAttributes="Bold" />
            </Border>
            <Label Grid.Column="2" Text="te iznosi:" VerticalOptions="Center" />
            <Border Grid.Column="3" Padding="8,4" StrokeShape="RoundRectangle 4" BackgroundColor="#E0E0E0">
                <Label Text="{Binding DegreeValue}" FontAttributes="Bold" />
            </Border>
        </Grid>

        <!-- Betweenness -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <Label Text="Najveću centralnost međupoloženosti ima vrh" VerticalOptions="Center" />
            <Border Grid.Column="1" Padding="8,4" StrokeShape="RoundRectangle 4" BackgroundColor="#E0E0E0">
                <Label Text="{Binding BetweennessVertices}" FontAttributes="Bold" />
            </Border>
            <Label Grid.Column="2" Text="te iznosi:" VerticalOptions="Center" />
            <Border Grid.Column="3" Padding="8,4" StrokeShape="RoundRectangle 4" BackgroundColor="#E0E0E0">
                <Label Text="{Binding BetweennessValue}" FontAttributes="Bold" />
            </Border>
        </Grid>

        <!-- Closeness -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <Label Text="Najveću centralnost bliskosti ima vrh" VerticalOptions="Center" />
            <Border Grid.Column="1" Padding="8,4" StrokeShape="RoundRectangle 4" BackgroundColor="#E0E0E0">
                <Label Text="{Binding ClosenessVertices}" FontAttributes="Bold" />
            </Border>
            <Label Grid.Column="2" Text="te iznosi:" VerticalOptions="Center" />
            <Border Grid.Column="3" Padding="8,4" StrokeShape="RoundRectangle 4" BackgroundColor="#E0E0E0">
                <Label Text="{Binding ClosenessValue}" FontAttributes="Bold" />
            </Border>
        </Grid>

    </VerticalStackLayout>
</ContentView>
