<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ExamPlanner.Views.CentralityResultsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ExamPlanner.ViewModels"
    x:DataType="vm:QuestionEditorViewModel">

    <VerticalStackLayout Spacing="12">

        <!--  Degree  -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <Label Text="Najveću centralnost stupnja ima vrh" VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding DegreeVertices}" />
            </Border>
            <Label
                Grid.Column="2"
                Text="te iznosi:"
                VerticalOptions="Center" />
            <Border
                Grid.Column="3"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding DegreeValue}" />
            </Border>
        </Grid>

        <!--  Betweenness  -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <Label Text="Najveću centralnost međupoloženosti ima vrh" VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding BetweennessVertices}" />
            </Border>
            <Label
                Grid.Column="2"
                Text="te iznosi:"
                VerticalOptions="Center" />
            <Border
                Grid.Column="3"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding BetweennessValue}" />
            </Border>
        </Grid>

        <!--  Closeness  -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <Label Text="Najveću centralnost bliskosti ima vrh" VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding ClosenessVertices}" />
            </Border>
            <Label
                Grid.Column="2"
                Text="te iznosi:"
                VerticalOptions="Center" />
            <Border
                Grid.Column="3"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding ClosenessValue}" />
            </Border>
        </Grid>

    </VerticalStackLayout>
</ContentView>
