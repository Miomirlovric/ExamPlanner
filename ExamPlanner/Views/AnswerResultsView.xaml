<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ExamPlanner.Views.AnswerResultsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ExamPlanner.Views"
    xmlns:vm="clr-namespace:ExamPlanner.ViewModels"
    x:DataType="vm:QuestionEditorViewModel">

    <VerticalStackLayout BindableLayout.ItemsSource="{Binding AnswerLines}" Spacing="12">
        <BindableLayout.ItemTemplate>
            <DataTemplate>
                <FlexLayout
                    AlignItems="Center"
                    BindableLayout.ItemsSource="{Binding Segments}"
                    Wrap="Wrap">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <views:AnswerSegmentView />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
            </DataTemplate>
        </BindableLayout.ItemTemplate>
    </VerticalStackLayout>
</ContentView>
