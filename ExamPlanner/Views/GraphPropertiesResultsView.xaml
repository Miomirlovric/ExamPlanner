<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ExamPlanner.Views.GraphPropertiesResultsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ExamPlanner.ViewModels"
    x:DataType="vm:SectionEditorViewModel">

    <VerticalStackLayout Spacing="12">
        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
            <Label Text="Dijametar grafa:" VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding DiameterValue}" />
            </Border>
        </Grid>
        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
            <Label Text="Gustoća grafa:" VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding DensityValue}" />
            </Border>
        </Grid>
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <Label Text="Najveći stupanj ima vrh" VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding MaxDegreeVertices}" />
            </Border>
            <Label
                Grid.Column="2"
                Text="te iznosi:"
                VerticalOptions="Center" />
            <Border
                Grid.Column="3"
                Padding="8,4"
                BackgroundColor="#E0E0E0"
                StrokeShape="RoundRectangle 4">
                <Label FontAttributes="Bold" Text="{Binding MaxDegreeValue}" />
            </Border>
        </Grid>
    </VerticalStackLayout>
</ContentView>
