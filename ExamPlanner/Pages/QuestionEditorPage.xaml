<?xml version="1.0" encoding="utf-8" ?>
<base:ContentPageBase
    x:Class="ExamPlanner.Pages.QuestionEditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:ExamPlanner.Base"
    xmlns:views="clr-namespace:ExamPlanner.Views"
    xmlns:vm="clr-namespace:ExamPlanner.ViewModels"
    Title="Question"
    x:DataType="vm:QuestionEditorViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!--  ===== INPUT Question =====  -->
            <VerticalStackLayout IsVisible="{Binding IsInputVisible}" Spacing="12">

                <Label
                    FontAttributes="Bold"
                    FontSize="20"
                    Text="Graph Input" />

                <HorizontalStackLayout Spacing="12">
                    <Label Text="Question Type" VerticalOptions="Center" />
                    <Picker
                        ItemDisplayBinding="{Binding Converter={StaticResource QuestionTypeConverter}}"
                        ItemsSource="{Binding QuestionTypes}"
                        SelectedItem="{Binding SelectedQuestionType}" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="12">
                    <Label Text="Random Graph" VerticalOptions="Center" />
                    <Switch IsToggled="{Binding UseRandomGeneration}" />
                </HorizontalStackLayout>

                <!--  Manual edge input  -->
                <VerticalStackLayout IsVisible="{Binding IsManualInput}" Spacing="8">
                    <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8">
                        <Entry
                            Grid.Column="0"
                            Placeholder="Source (e.g. A)"
                            Text="{Binding SourceVertex}" />
                        <Entry
                            Grid.Column="1"
                            Placeholder="Target (e.g. B)"
                            Text="{Binding TargetVertex}" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding AddEdgeCommand}"
                            Text="+"
                            WidthRequest="50" />
                    </Grid>

                    <CollectionView HeightRequest="200" ItemsSource="{Binding Edges}">
                        <CollectionView.EmptyView>
                            <Label
                                Padding="8"
                                Opacity="0.5"
                                Text="No edges added yet." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:EdgeItem">
                                <Border
                                    Margin="0,2"
                                    Padding="8,4"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label
                                            FontSize="16"
                                            Text="{Binding Display}"
                                            VerticalOptions="Center" />
                                        <Button
                                            Grid.Column="1"
                                            Padding="0"
                                            BackgroundColor="Transparent"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveEdgeCommand}"
                                            CommandParameter="{Binding}"
                                            FontSize="14"
                                            HeightRequest="36"
                                            Text="✕"
                                            TextColor="Red"
                                            WidthRequest="36" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!--  Random generation input  -->
                <VerticalStackLayout IsVisible="{Binding IsRandomInput}" Spacing="8">
                    <Label Text="Number of Vertices" />
                    <Entry
                        Keyboard="Numeric"
                        Placeholder="e.g. 8"
                        Text="{Binding VertexCount}" />
                </VerticalStackLayout>

                <HorizontalStackLayout Spacing="12">
                    <Label Text="Directed Graph" VerticalOptions="Center" />
                    <Switch IsEnabled="{Binding IsDirectedEnabled}" IsToggled="{Binding IsDirected}" />
                </HorizontalStackLayout>

                <Button Command="{Binding GenerateCommand}" Text="Generate" />
            </VerticalStackLayout>

            <!--  ===== RESULTS Question =====  -->
            <VerticalStackLayout IsVisible="{Binding IsGenerated}" Spacing="16">

                <Label FontSize="14" Text="{Binding QuestionText}" />

                <Border
                    Padding="4"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 8">
                    <Image
                        Aspect="AspectFit"
                        HeightRequest="300"
                        Source="{Binding GraphImageSource}" />
                </Border>

                <!--  Results based on question type  -->
                <views:AnswerResultsView />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button
                        BackgroundColor="{StaticResource Gray200}"
                        Command="{Binding EditGraphCommand}"
                        Text="Edit Graph"
                        TextColor="Black" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding SaveCommand}"
                        Text="Save Question" />
                </Grid>
            </VerticalStackLayout>

            <!--  Loading  -->
            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</base:ContentPageBase>
